{
  "name": "chatcommander",
  "version": "1.0.0",
  "description": "A Twitch bot with C++ reactor",
  "main": "main.js",
  "scripts": {
    "test": "echo \"Error: no test specified\" && exit 1",
    "electron": "electron .",
    "build": "electron-builder build --win"
  },
  "build": {
    "forceCodeSigning": false,
    "appId": "com.chatcommander.app",
    "productName": "ChatCommander",
    "directories": {
      "output": "dist"
    },
 "win": {
    "target": "nsis",
    "forceCodeSigning": false
},
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    },
    "files": [
    "**/*",
    ".env",
    "!node_modules/electron-builder/**",
    "!node_modules/.cache/**"
],
    "extraResources": [
  { "from": "reactor.exe", "to": "reactor.exe" },
  { "from": ".env", "to": ".env" }
]
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "axios": "^1.13.6",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "tmi.js": "^1.8.5"
  },
  "devDependencies": {
    "electron": "^40.7.0",
    "electron-builder": "^26.0.12",
    "jimp": "^1.6.0",
    "png-to-ico": "^3.0.1"
  }
}
